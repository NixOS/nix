Nix <nix version>
Type :? for help.

nix-repl> { a = { b = 2; }; l = [ 1 2 3 ]; s = "string"; n = 1234; x = rec { y = { z = { inherit y; }; }; }; }
{
  a = { ... };
  l = [ ... ];
  n = 1234;
  s = "string";
  x = { ... };
}

nix-repl> [ 42 1 "thingy" ({ a = 1; }) ([ 1 2 3 ]) ]
[
  42
  1
  "thingy"
  { ... }
  [ ... ]
]

nix-repl> let x = { y = { a = 1; }; inherit x; }; in x
{
  x = «repeated»;
  y = { ... };
}

nix-repl> :p { a = { b = 2; }; s = "string"; n = 1234; x = rec { y = { z = { inherit y; }; }; }; }
{
  a = { b = 2; };
  n = 1234;
  s = "string";
  x = {
    y = {
      z = {
        y = «repeated»;
      };
    };
  };
}

nix-repl> :p [ 42 1 "thingy" (rec { a = 1; b = { inherit a; inherit b; }; }) ([ 1 2 3 ]) ]
[
  42
  1
  "thingy"
  {
    a = 1;
    b = {
      a = 1;
      b = «repeated»;
    };
  }
  [
    1
    2
    3
  ]
]
